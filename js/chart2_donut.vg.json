{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Share of Total Household Expenditure",
    "fontSize": 14,
    "fontWeight": 600,
    "color": "#1a2a3a"
  },
  "width": "container",
  "height": 400,
  "config": {
    "view": {"stroke": "transparent"}
  },
  "data": {"values": [{"category":"Transport","amount":14013.2,"color_order":1},{"category":"Recreation & Culture","amount":13436.5,"color_order":2},{"category":"Food","amount":12555.4,"color_order":3},{"category":"Hotels Cafes & Restaurants","amount":10834.2,"color_order":4},{"category":"Health","amount":9395.7,"color_order":5},{"category":"Miscellaneous Goods & Services","amount":7391.5,"color_order":6},{"category":"Furnishings & Household Equipment","amount":5494.8,"color_order":7},{"category":"Clothing & Footwear","amount":4497.7,"color_order":8},{"category":"Alcoholic Beverages & Tobacco","amount":2794.1,"color_order":9}]},
  "mark": {"type": "arc", "innerRadius": 80, "tooltip": {"content": "data"}},
  "encoding": {
    "theta": {"field": "amount", "type": "quantitative", "stack": true},
    "color": {
      "field": "category",
      "type": "nominal",
      "scale": {
        "domain": [
          "Transport",
          "Recreation & Culture",
          "Food",
          "Hotels Cafes & Restaurants",
          "Health",
          "Miscellaneous Goods & Services",
          "Furnishings & Household Equipment",
          "Clothing & Footwear",
          "Alcoholic Beverages & Tobacco"
        ],
        "range": [
          "#9b59b6",
          "#f39c12",
          "#e67e22",
          "#d35400",
          "#2980b9",
          "#34495e",
          "#5d6d7e",
          "#e91e63",
          "#8e44ad"
        ]
      },
      "legend": {
        "orient": "right",
        "title": null,
        "labelFontSize": 11,
        "symbolSize": 80,
        "rowPadding": 8,
        "labelExpr": "datum.label == 'Furnishings & Household Equipment' ? ['Furnishings &', 'Household Equipment'] : datum.label == 'Miscellaneous Goods & Services' ? ['Miscellaneous Goods &', 'Services'] : datum.label == 'Alcoholic Beverages & Tobacco' ? ['Alcoholic Beverages &', 'Tobacco'] : datum.label"
      }
    },
    "tooltip": [
      {"field": "category", "type": "nominal", "title": "Category"},
      {"field": "amount", "type": "quantitative", "title": "Amount (AUD Mn)", "format": ",.1f"},
      {"field": "percentage", "type": "quantitative", "title": "Share (%)", "format": ".1%"}
    ]
  },
  "transform": [
    {"window": [{"op": "sum", "field": "amount", "as": "total"}],
     "frame": [null,null]
    },
    {"calculate": "datum.amount / datum.total", "as": "percentage"}
  ]
}
